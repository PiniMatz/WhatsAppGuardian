<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0f172a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡️"
            android:textSize="64sp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שומר וואטסאפ"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#f8fafc"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הגדרת אפליקציית הילד"
            android:textSize="16sp"
            android:textColor="#94a3b8"
            android:layout_marginTop="8dp"/>

        <!-- Kid Name Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:background="#1e293b"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שם הילד/ה:"
                android:textColor="#cbd5e1"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_gravity="right"/>

            <EditText
                android:id="@+id/et_kid_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="#0f172a"
                android:padding="10dp"
                android:textColor="#f8fafc"
                android:hint="לדוגמה: נועם"
                android:textColorHint="#475569"
                android:gravity="right"
                android:inputType="text"/>

            <Button
                android:id="@+id/btn_save_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="#6366f1"
                android:text="שמור שם ילד"
                android:textColor="#ffffff"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Settings Links -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="נדרש לאפשר את ההרשאות הבאות:"
            android:textColor="#cbd5e1"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#475569"
            android:text="אפשר שירות נגישות (Accessibility)"
            android:textColor="#ffffff"/>

        <Button
            android:id="@+id/btn_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#475569"
            android:text="אפשר גישה להתראות (Notifications)"
            android:textColor="#ffffff"/>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="סטטוס שירות: כבוי"
            android:textColor="#ef4444"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:textSize="14sp"/>

        <!-- Help / Setup Instructions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:background="#334155"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 הנחיות התקנה חשובות (אנדרואיד 13+ / Family Link):"
                android:textColor="#f8fafc"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_gravity="right"
                android:gravity="right"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="1. במידה ומתקבלת הודעה 'הגדרה מוגבלת' (Restricted Setting) בניסיון להפעיל נגישות:\n• כנס להגדרות המכשיר -> יישומים -> WhatsApp Guardian.\n• לחץ על 3 הנקודות בפינה העליונה ולחץ על 'אפשר הגדרות מוגבלות' (Allow Restricted Settings).\n• כעת חזור לאפליקציה זו והפעל את שירות הנגישות בהצלחה.\n\n2. בתוך Google Family Link:\n• יש לוודא שאישרת 'אפשרויות מפתח' (Developer Options) בהגדרות המכשיר של הילד דרך אפליקציית ההורים כדי לאפשר את התקנת האפליקציה."
                android:textColor="#cbd5e1"
                android:textSize="13sp"
                android:gravity="right"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
